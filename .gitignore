# ============================================================
# Spring Boot / Java 21 / WAR - .gitignore
# ============================================================

# ---- Compiled output ----
target/
*.class
*.war
*.jar
*.ear

# ---- Maven ----
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# ---- Gradle (nếu dùng song song) ----
.gradle/
build/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# ---- IDE - IntelliJ IDEA ----
.idea/
*.iml
*.iws
*.ipr
out/

# ---- IDE - Eclipse / STS ----
.classpath
.project
.settings/
.springBeans
.sts4-cache/
bin/

# ---- IDE - VS Code ----
.vscode/
*.code-workspace

# ---- IDE - NetBeans ----
nbproject/
nbbuild/
nbdist/
nb-configuration.xml

# ---- Spring Boot ----
spring-shell.log
*.log
logs/

# ---- Environment & Secrets (QUAN TRỌNG) ----
.env
.env.*
application-local.properties
application-local.yml
application-prod.properties
application-prod.yml
application-secret.properties
application-secret.yml
**/src/main/resources/application-local.*
**/src/main/resources/application-prod.*

# ---- OS ----
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ---- Upload / Static files sinh ra lúc runtime ----
uploads/
src/main/webapp/uploads/
src/main/resources/static/uploads/

# ---- Tomcat embedded / external ----
work/
temp/